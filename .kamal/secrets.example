# Copy to .kamal/secrets and adjust. DO NOT commit real secrets.
# Same pattern as other Kamal apps: password manager + AWS ECR login.
#
#   cp .kamal/secrets.example .kamal/secrets
#
# Requires: op CLI / kamal 1password adapter (or fill env another way),
#           aws CLI profile with ECR push access.

# Cloudflare origin certs (example: 1Password item in your vault)
# Replace ACCOUNT / VAULT with your own 1Password setup.
SECRETS=$(kamal secrets fetch --adapter 1password --account YOUR_1PASSWORD_ACCOUNT \
  --from "YOUR_VAULT/Production" CLOUDFLARE_SSL_CERT_PEM CLOUDFLARE_SSL_KEY_PEM)
CLOUDFLARE_SSL_CERT_PEM=$(kamal secrets extract CLOUDFLARE_SSL_CERT_PEM ${SECRETS})
CLOUDFLARE_SSL_KEY_PEM=$(kamal secrets extract CLOUDFLARE_SSL_KEY_PEM ${SECRETS})

# Hugging Face — accept MuScriptor license, then either:
#   export HF_TOKEN=hf_...
# or store HF_TOKEN in your password manager and extract similarly.
# Required to pull gated weights on first boot.
if [ -z "${HF_TOKEN:-}" ]; then
  echo "Warning: HF_TOKEN not set in environment. Set it before kamal deploy." >&2
fi
HF_TOKEN=${HF_TOKEN}

# ECR (use your registry region/profile)
AWS_ECR_PASSWORD=$(aws ecr get-login-password --region YOUR_AWS_REGION --profile default)
